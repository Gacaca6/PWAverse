{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PWAverse directory data",
  "type": "object",
  "required": ["categories", "apps"],
  "properties": {
    "$schema": { "type": "string" },
    "categories": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "apps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "url", "description", "category", "iconLetter", "iconColor", "tags", "added", "submittedBy"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
            "description": "Unique lowercase-hyphenated identifier"
          },
          "name": { "type": "string", "minLength": 1, "maxLength": 60 },
          "url": { "type": "string", "pattern": "^https://" },
          "description": { "type": "string", "minLength": 20, "maxLength": 200 },
          "category": { "type": "string" },
          "iconLetter": { "type": "string", "minLength": 1, "maxLength": 2 },
          "iconColor": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
          "tags": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
            "maxItems": 4
          },
          "added": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "submittedBy": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
